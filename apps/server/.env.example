# ─────────────────────────────────────────────────────────────────────────
# Baret Casper server config
# ─────────────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info
NODE_ENV=development

# Comma-separated API keys gating POST /v1/* (empty = open; warns in prod).
DELTAG_API_KEYS=dev-key-change-me

# --- Casper network ---
# testnet | mainnet. RPC URL defaults from @casper-baret/casper-core NETWORKS.
CASPER_NETWORK=testnet
# Override the default RPC node if needed.
# CASPER_RPC_URL=https://node.testnet.casper.network/rpc

# --- x402 paywall (GET /demo/scrybe) ---
# Enable HTTP 402 settlement over a CEP-18 token via a casper-x402 facilitator.
X402_ENABLED=true
# make-software/casper-x402 facilitator. Run one locally on :4022 for dev.
X402_FACILITATOR_URL=http://localhost:4022
# CEP-18 contract package hash (64 hex) used as the settlement asset.
CEP18_X402_PACKAGE=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
# Payee: x402 wire addr ("00"+64hex) or a bare 64-hex account hash.
X402_PAY_TO=bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
# Atomic token amount charged per answer.
X402_PRICE_ATOMIC=10000
# EIP-712 domain fields for the CEP-18 token (must match on-chain metadata).
X402_TOKEN_NAME=Cep18x402
X402_TOKEN_VERSION=1

# --- Contract reputation (csv of 64-hex contract package hashes) ---
RISKY_CONTRACT_PACKAGES=
KNOWN_SAFE_CONTRACT_PACKAGES=

# --- Request limits ---
MAX_BODY_BYTES=1048576
REQUEST_TIMEOUT_MS=25000
DELTAG_RATE_LIMIT_MAX=200
DELTAG_RATE_LIMIT_WINDOW_MS=60000
# 1/true: trust X-Forwarded-For (behind a reverse proxy / Docker).
DELTAG_TRUST_PROXY=
