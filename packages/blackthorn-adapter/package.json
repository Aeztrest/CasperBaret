{
  "name": "@casper-baret/wallet-adapter",
  "version": "0.1.0",
  "private": true,
  "description": "Popup-bridge wallet adapter — dApps connect to the BLACKTHORN smart wallet over postMessage. Every signature passes the wallet's policy gate.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
